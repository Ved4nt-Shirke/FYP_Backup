import React, { useState } from 'react';
import { useNavigate } from 'react-router-dom';

const SuperAdminDashboard = () => {
  const navigate = useNavigate();
  const [showUpdateCredentialsModal, setShowUpdateCredentialsModal] = useState(false);
  const [credentialsFormData, setCredentialsFormData] = useState({
    newUsername: '',
    newPassword: '',
    superadminPassword: '',
    confirmation: ''
  });

  const dashboardCards = [
    {
      title: "Create Institution",
      description: "Add a new institution to the system with admin credentials.",
      icon: "fas fa-university",
      action: () => navigate('/superadmin-create-institution'),
      color: "primary"
    },
    {
      title: "View Institutions",
      description: "See all institutions and their admin credentials.",
      icon: "fas fa-list",
      action: () => navigate('/superadmin-view-institutions'),
      color: "secondary"
    },
    {
      title: "Update Superadmin Credentials",
      description: "Change the superadmin username and password.",
      icon: "fas fa-user-shield",
      action: () => setShowUpdateCredentialsModal(true),
      color: "warning"
    },
    {
      title: "System Stats",
      description: "View system-wide statistics and metrics.",
      icon: "fas fa-chart-bar",
      action: () => {},
      color: "info",
      disabled: true
    }
  ];

  return (
    <div className="container-fluid mt-4">
      <div className="row">
        <div className="col-12">
          <div className="d-flex justify-content-between align-items-center mb-4">
            <div>
              <h2 className="mb-0">Super Admin Dashboard</h2>
              <p className="text-muted mb-0">Manage all institutions in the system</p>
            </div>
            <div className="d-flex gap-2">
              <button className="btn btn-outline-primary">
                <i className="fas fa-sync-alt me-2"></i>Refresh
              </button>
            </div>
          </div>
        </div>
      </div>
      
      <div className="row">
        {dashboardCards.map((card, index) => (
          <div className="col-md-6 col-lg-4 mb-4" key={index}>
            <div className="card h-100 shadow-sm border-0">
              <div className="card-body d-flex flex-column">
                <div className="d-flex align-items-center mb-3">
                  <div className={`bg-${card.color} text-white rounded-circle p-3 me-3`}>
                    <i className={`${card.icon} fa-lg`}></i>
                  </div>
                  <h5 className="card-title mb-0">{card.title}</h5>
                </div>
                <p className="card-text text-muted flex-grow-1">{card.description}</p>
                <button 
                  className={`btn btn-${card.color} mt-3`}
                  onClick={card.action}
                  disabled={card.disabled}
                >
                  {card.disabled ? 'Coming Soon' : `Go to ${card.title}`}
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <div className="row mt-4">
        <div className="col-12">
          <div className="card border-0 shadow-sm">
            <div className="card-header bg-white py-3">
              <h5 className="mb-0">Recent Activity</h5>
            </div>
            <div className="card-body">
              <div className="d-flex align-items-center py-3 border-bottom">
                <div className="bg-light rounded-circle p-2 me-3">
                  <i className="fas fa-plus text-success"></i>
                </div>
                <div className="flex-grow-1">
                  <h6 className="mb-0">New Institution Created</h6>
                  <p className="text-muted mb-0 small">Vidyalankar Polytechnic was created 2 hours ago</p>
                </div>
                <span className="text-muted small">2h ago</span>
              </div>
              <div className="d-flex align-items-center py-3 border-bottom">
                <div className="bg-light rounded-circle p-2 me-3">
                  <i className="fas fa-user-plus text-primary"></i>
                </div>
                <div className="flex-grow-1">
                  <h6 className="mb-0">Admin User Added</h6>
                  <p className="text-muted mb-0 small">New admin user for VIT created 1 day ago</p>
                </div>
                <span className="text-muted small">1d ago</span>
              </div>
              <div className="d-flex align-items-center py-3">
                <div className="bg-light rounded-circle p-2 me-3">
                  <i className="fas fa-cog text-info"></i>
                </div>
                <div className="flex-grow-1">
                  <h6 className="mb-0">System Update</h6>
                  <p className="text-muted mb-0 small">System updated to version 2.1.0 3 days ago</p>
                </div>
                <span className="text-muted small">3d ago</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
};

  const handleCredentialsUpdate = async (e) => {
    e.preventDefault();
    
    // Validation
    if (!credentialsFormData.superadminPassword) {
      alert('Superadmin password is required');
      return;
    }
    
    if (!credentialsFormData.confirmation || credentialsFormData.confirmation !== 'CONFIRM') {
      alert('Please type "CONFIRM" to proceed');
      return;
    }
    
    if (!credentialsFormData.newUsername && !credentialsFormData.newPassword) {
      alert('Either new username or new password must be provided');
      return;
    }
    
    try {
      const token = localStorage.getItem('token');
      const response = await fetch('/api/superadmin/update-superadmin-credentials', {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
          newUsername: credentialsFormData.newUsername || undefined,
          newPassword: credentialsFormData.newPassword || undefined,
          superadminPassword: credentialsFormData.superadminPassword,
          confirmation: credentialsFormData.confirmation
        })
      });
      
      const data = await response.json();
      
      if (data.success) {
        alert('Superadmin credentials updated successfully!');
        setShowUpdateCredentialsModal(false);
        // Reset form
        setCredentialsFormData({
          newUsername: '',
          newPassword: '',
          superadminPassword: '',
          confirmation: ''
        });
      } else {
        alert('Error: ' + (data.message || 'Failed to update credentials'));
      }
    } catch (error) {
      console.error('Error updating credentials:', error);
      alert('Error updating credentials: ' + error.message);
    }
  };

  return (
    <div className=\"container-fluid mt-4\">
      <div className=\"row\">
        <div className=\"col-12\">
          <div className=\"d-flex justify-content-between align-items-center mb-4\">
            <div>
              <h2 className=\"mb-0\">Super Admin Dashboard</h2>
              <p className=\"text-muted mb-0\">Manage all institutions in the system</p>
            </div>
            <div className=\"d-flex gap-2\">
              <button className=\"btn btn-outline-primary\">
                <i className=\"fas fa-sync-alt me-2\"></i>Refresh
              </button>
            </div>
          </div>
        </div>
      </div>
      
      <div className=\"row\">
        {dashboardCards.map((card, index) => (
          <div className=\"col-md-6 col-lg-4 mb-4\" key={index}>
            <div className=\"card h-100 shadow-sm border-0\">
              <div className=\"card-body d-flex flex-column\">
                <div className=\"d-flex align-items-center mb-3\">
                  <div className={`bg-${card.color} text-white rounded-circle p-3 me-3`}>
                    <i className={`${card.icon} fa-lg`}></i>
                  </div>
                  <h5 className=\"card-title mb-0\">{card.title}</h5>
                </div>
                <p className=\"card-text text-muted flex-grow-1\">{card.description}</p>
                <button 
                  className={`btn btn-${card.color} mt-3`}
                  onClick={card.action}
                  disabled={card.disabled}
                >
                  {card.disabled ? 'Coming Soon' : `Go to ${card.title}`}
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <div className=\"row mt-4\">
        <div className=\"col-12\">
          <div className=\"card border-0 shadow-sm\">
            <div className=\"card-header bg-white py-3\">
              <h5 className=\"mb-0\">Recent Activity</h5>
            </div>
            <div className=\"card-body\">
              <div className=\"d-flex align-items-center py-3 border-bottom\">
                <div className=\"bg-light rounded-circle p-2 me-3\">
                  <i className=\"fas fa-plus text-success\"></i>
                </div>
                <div className=\"flex-grow-1\">
                  <h6 className=\"mb-0\">New Institution Created</h6>
                  <p className=\"text-muted mb-0 small\">Vidyalankar Polytechnic was created 2 hours ago</p>
                </div>
                <span className=\"text-muted small\">2h ago</span>
              </div>
              <div className=\"d-flex align-items-center py-3 border-bottom\">
                <div className=\"bg-light rounded-circle p-2 me-3\">
                  <i className=\"fas fa-user-plus text-primary\"></i>
                </div>
                <div className=\"flex-grow-1\">
                  <h6 className=\"mb-0\">Admin User Added</h6>
                  <p className=\"text-muted mb-0 small\">New admin user for VIT created 1 day ago</p>
                </div>
                <span className=\"text-muted small\">1d ago</span>
              </div>
              <div className=\"d-flex align-items-center py-3\">
                <div className=\"bg-light rounded-circle p-2 me-3\">
                  <i className=\"fas fa-cog text-info\"></i>
                </div>
                <div className=\"flex-grow-1\">
                  <h6 className=\"mb-0\">System Update</h6>
                  <p className=\"text-muted mb-0 small\">System updated to version 2.1.0 3 days ago</p>
                </div>
                <span className=\"text-muted small\">3d ago</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Update Credentials Modal */}
      {showUpdateCredentialsModal && (
        <div className=\"modal show d-block\" tabIndex=\"-1\" role=\"dialog\">
          <div className=\"modal-dialog modal-dialog-centered\" role=\"document\">
            <div className=\"modal-content\">
              <div className=\"modal-header\">
                <h5 className=\"modal-title\">Update Superadmin Credentials</h5>
                <button type=\"button\" className=\"btn-close\" onClick={() => setShowUpdateCredentialsModal(false)} aria-label=\"Close\"></button>
              </div>
              <form onSubmit={handleCredentialsUpdate}>
                <div className=\"modal-body\">
                  <div className=\"alert alert-info\">
                    <p className=\"mb-0\">You can update either the username, password, or both. Leave fields blank to keep current values.</p>
                  </div>
                  
                  <div className=\"mb-3\">
                    <label className=\"form-label\">New Username (optional)</label>
                    <input
                      type=\"text\"
                      className=\"form-control\"
                      placeholder=\"Enter new username\"
                      value={credentialsFormData.newUsername}
                      onChange={(e) => setCredentialsFormData({...credentialsFormData, newUsername: e.target.value})}
                    />
                  </div>
                  
                  <div className=\"mb-3\">
                    <label className=\"form-label\">New Password (optional)</label>
                    <input
                      type=\"password\"
                      className=\"form-control\"
                      placeholder=\"Enter new password\"
                      value={credentialsFormData.newPassword}
                      onChange={(e) => setCredentialsFormData({...credentialsFormData, newPassword: e.target.value})}
                    />
                  </div>
                  
                  <div className=\"mb-3\">
                    <label className=\"form-label\">Current Superadmin Password <span className=\"text-danger\">*</span></label>
                    <input
                      type=\"password\"
                      className=\"form-control\"
                      placeholder=\"Enter current superadmin password\"
                      required
                      value={credentialsFormData.superadminPassword}
                      onChange={(e) => setCredentialsFormData({...credentialsFormData, superadminPassword: e.target.value})}
                    />
                    <div className=\"form-text\">Required for security verification</div>
                  </div>
                  
                  <div className=\"mb-3\">
                    <label className=\"form-label\">Confirmation <span className=\"text-danger\">*</span></label>
                    <input
                      type=\"text\"
                      className=\"form-control\"
                      placeholder=\"Type CONFIRM to proceed\"
                      required
                      value={credentialsFormData.confirmation}
                      onChange={(e) => setCredentialsFormData({...credentialsFormData, confirmation: e.target.value})}
                    />
                    <div className=\"form-text\">Type \"CONFIRM\" to proceed with the update</div>
                  </div>
                </div>
                <div className=\"modal-footer\">
                  <button type=\"button\" className=\"btn btn-secondary\" onClick={() => setShowUpdateCredentialsModal(false)}>Cancel</button>
                  <button type=\"submit\" className=\"btn btn-warning\">Update Credentials</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      )}

      {/* Modal backdrop */}
      {showUpdateCredentialsModal && (
        <div className=\"modal-backdrop show\"></div>
      )}
    </div>
  );
};

export default SuperAdminDashboard;